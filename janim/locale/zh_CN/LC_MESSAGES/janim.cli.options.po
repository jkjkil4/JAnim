#: janim/cli/options.py:16
msgid "Extract all timelines from the file"
msgstr "提取文件中的所有 Timeline"

#: janim/cli/options.py:25
msgid "Override config"
msgstr "覆盖设置"

#: janim/cli/options.py:30
msgid "Hide subtitles"
msgstr "隐藏字幕"

#: janim/cli/options.py:34
msgid "Use external Typst executable for compiling Typst documents"
msgstr "使用外部 Typst 可执行文件来编译 Typst 文档"

#: janim/cli/options.py:45
msgid "Enable the network socket for interacting with VS Code"
msgstr "启用与 VS Code 交互的网络端口"

#: janim/cli/options.py:53
msgid "Watches the file and rebuild on changes"
msgstr "监听文件并在变化时重新构建"

#: janim/cli/options.py:65
msgid "Output video format (mp4 by default, mov for transparent background)"
msgstr "输出视频的格式（默认 mp4；透明背景需使用 mov）"

#: janim/cli/options.py:72
msgid "Output audio format (valid only when outputting audio separately)"
msgstr "输出音频的格式（仅在单独输出音频时有效）"

#: janim/cli/options.py:85
msgid ""
"Video with audio (default; will be replaced by --video if there is no audio, and by both --video and --audio if the "
"format is GIF)"
msgstr "带有音频的视频（默认，当没有音频时会被 --video 替代，当格式为 GIF 时会被 --video 和 --audio 替代）"

#: janim/cli/options.py:94
msgid "Video only"
msgstr "仅视频"

#: janim/cli/options.py:102
msgid "Audio only"
msgstr "仅音频"

#: janim/cli/options.py:110
msgid "Generate SRT file"
msgstr "生成 SRT 文件"

#: janim/cli/options.py:121
msgid "Set In Point; use negative value to indicate time relative to the end"
msgstr "设置入点; 使用负值表示相对结尾的时间点"

#: janim/cli/options.py:128
msgid "Set Out Point; use negative value to indicate time relative to the end"
msgstr "设置出点; 使用负值表示相对结尾的时间点"

#: janim/cli/options.py:140
msgid "Disable PBO (Pixel Buffer Object) for writing video"
msgstr "在输出视频时禁用 PBO（像素缓冲对象）"

#: janim/cli/options.py:148
msgid "Use hardware acceleration for writing video"
msgstr "在输出视频时使用硬件加速"
