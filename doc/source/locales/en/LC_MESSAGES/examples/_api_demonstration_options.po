"from janim.imports import *\n"
"\n"
"typst_doc = t_(\n"
"R'''\n"
"JAnim provides `TypstText` and `TypstMath` classes to insert Typst content.\n"
"\n"
"Math expressions are also supported.\n"
"\n"
"$ A = pi r^2 $\n"
"$ \"area\" = pi dot \"radius\"^2 $\n"
"$ cal(A) :=\n"
"    { x in RR | x \"is natural\" } $\n"
"#let x = 5\n"
