#: ../../source/tutorials/camera_usage.rst:19
msgid "摄像机物件像普通物件一样平移、旋转以及缩放："
msgstr ""

#: ../../source/tutorials/camera_usage.rst:13
msgid ""
"# 螺线参数方程\n"
"def t_func(self, t):\n"
"    scale = 0.01\n"
"    return np.array([\n"
"        scale * np.cos(t) * t**2,\n"
"        scale * np.sin(t) * t**2,\n"
"        0,\n"
"    ])\n"
"\n"
"# 坐标系\n"
"plane = NumberPlane(faded_line_ratio=1)\n"
"# 创建螺线\n"
"curve = ParametricCurve(t_func, t_range=[0, 5 * TAU, 0.2], color=YELLOW)\n"
"\n"
"self.show(plane, curve)\n"
"\n"
"self.forward()\n"
"self.play(\n"
"    self.camera.anim.points.rotate(PI / 2).scale(0.25), # 旋转并缩放相机\n"
"    curve.anim.radius.scale(0.25),  # 缩放螺线粗细\n"
"    duration=3\n"
")\n"
"self.forward()"
msgstr ""

