"            TransformMatchingDiff(typ1[2:], typ2[2:])\n"
"        )\n"
"        self.forward()\n"
"\n"
"        typ1 = TypstDoc(typ1_src).show()\n"
"        typ2 = TypstDoc(typ2_src)"

