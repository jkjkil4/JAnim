#: ../../source/janim/items/svg/typst_types.rst:2
msgid "typst_types"
msgstr "typst_types"

#: janim.items.svg.typst_types.TypstMatrix:1 of
msgid "使用 Typst 进行矩阵布局"
msgstr "Use Typst for matrix layout"

#: janim.items.svg.typst_types.TypstMatrix:3 of
msgid "使用 :meth:`get_inserted` 得到插入的 JAnim 物件"
msgstr "Use :meth:`get_inserted` to get inserted JAnim items"

#: janim.items.svg.typst_types.TypstMatrix:4 of
msgid "使用 :meth:`get_element` 根据行列得到元素（需要传入 ``label=True`` 启用）"
msgstr "Use :meth:`get_element` to get elements by row and column (requires passing ``label=True`` to enable)"

#: janim.items.svg.typst_types.TypstMatrix:6 of
msgid "传参请参考 Typst 文档 https://typst.app/docs/reference/math/mat/ ，以下给出部分示例"
msgstr ""
"For parameter passing, please refer to Typst documentation https://typst.app/docs/reference/math/mat/; some examples are "
"given below"

#: janim.items.svg.typst_types.TypstMatrix:8 of
msgid ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Arrow(ORIGIN, RIGHT), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
").show()"
msgstr ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Arrow(ORIGIN, RIGHT), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
").show()"

#: janim.items.svg.typst_types.TypstMatrix:18 of
msgid ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Arrow(ORIGIN, RIGHT), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
"    gap='2em',\n"
").show()"
msgstr ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Arrow(ORIGIN, RIGHT), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
"    gap='2em',\n"
").show()"

#: janim.items.svg.typst_types.TypstMatrix:29 of
msgid ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Arrow(ORIGIN, RIGHT), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
"    delim='[',\n"
"    align='right',\n"
"    augment=2,\n"
"    gap='0.5em',\n"
")"
msgstr ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Arrow(ORIGIN, RIGHT), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
"    delim='[',\n"
"    align='right',\n"
"    augment=2,\n"
"    gap='0.5em',\n"
")"

#: janim.items.svg.typst_types.TypstMatrix:43 of
msgid ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Circle(radius=0.25, fill_alpha=0.5), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
"    delim='[',\n"
"    augment=2,\n"
"    column_gap='0.7em',\n"
"    preamble='#set text(size: 3em)'\n"
").show()"
msgstr ""
"TypstMatrix(\n"
"    [\n"
"        [1, 2, 3],\n"
"        [4, Circle(radius=0.25, fill_alpha=0.5), 6],\n"
"        [7, 8, 9]\n"
"    ],\n"
"    delim='[',\n"
"    augment=2,\n"
"    column_gap='0.7em',\n"
"    preamble='#set text(size: 3em)'\n"
").show()"

#: ../../docstring janim.items.svg.typst_types.TypstMatrix.matrix_labels:1 of
msgid "按照子物件顺序排列的矩阵元素标签"
msgstr "Matrix element labels arranged in child item order"

#: janim.items.svg.typst_types.TypstMatrix.get_inserted:1 of
msgid "获取插入的第 ``index`` 个 JAnim 物件"
msgstr "Get the ``index``-th inserted JAnim item"

#: janim.items.svg.typst_types.TypstMatrix.get_inserted:3 of
msgid "``index`` 从 0 开始计数"
msgstr "``index`` starts counting from 0"

#: janim.items.svg.typst_types.TypstMatrix.get_element:1 of
msgid "根据行列索引元素"
msgstr "Index element by row and column"

#: janim.items.svg.typst_types.TypstMatrix.get_element:3 janim.items.svg.typst_types.TypstMatrix.get_elements:3
#: janim.items.svg.typst_types.TypstMatrix.get_left_brace:3 janim.items.svg.typst_types.TypstMatrix.get_right_brace:3 of
msgid "需要在构造 :class:`TypstMatrix` 时传入 ``label=True`` 启用"
msgstr "Requires passing ``label=True`` when constructing :class:`TypstMatrix` to enable"

#: janim.items.svg.typst_types.TypstMatrix.get_elements:1 of
msgid "获取矩阵中所有元素"
msgstr "Get all elements in the matrix"

#: janim.items.svg.typst_types.TypstMatrix.get_left_brace:1 of
msgid "获取左大括号元素"
msgstr "Get the left brace element"

#: janim.items.svg.typst_types.TypstMatrix.get_right_brace:1 of
msgid "获取右大括号元素"
msgstr "Get the right brace element"

#: janim.items.svg.typst_types.DynamicTypst:1 of
msgid "便于创建参数变化的 Typst 物件的封装"
msgstr "A wrapper to conveniently create Typst items with parameter variations"

#: janim.items.svg.typst_types.DynamicTypst.anim_update of
msgid "参数"
msgstr "Parameters"

#: janim.items.svg.typst_types.DynamicTypst:3 of
msgid "Typst 代码"
msgstr "Typst code"

#: janim.items.svg.typst_types.DynamicTypst:4 of
msgid "声明含有哪些参数及其初始值，这些值可以直接在 Typst 代码中使用"
msgstr "Declare which parameters and their initial values; these can be used directly within the Typst code"

#: janim.items.svg.typst_types.DynamicTypst:5 of
msgid "用于在生成 Typst 对象后，做进一步的调整，例如固定或对齐某个位置"
msgstr "Used to make further adjustments after generating the Typst item, e.g., pinning or aligning a position"

#: janim.items.svg.typst_types.DynamicTypst:7 of
msgid "例："
msgstr "Example:"

#: ../../source/janim/items/svg/typst_types.rst:20
#, python-brace-format
msgid ""
"from janim.imports import *\n"
"\n"
"class DynamicTypstExample(Timeline):\n"
"    def construct(self) -> None:\n"
"        dtyp = DynamicTypst(\n"
"            \"\"\"\n"
"            #import \"@preview/cetz:0.4.2\"\n"
"            #import \"@preview/cetz-plot:0.1.3\": *\n"
"\n"
"            #let width = 1\n"
"            #let ang_deg = angle * 1deg\n"
"\n"
"            #cetz.canvas({\n"
"                import cetz.draw: *\n"
"\n"
"                stroke((thickness: 0.7pt, join: \"round\", paint: white))\n"
"\n"
"                let (a, b, c, d) = (\n"
"                    (0, 0),\n"
"                    (width, 0),\n"
"                    (rel: (width, 0), to: (60deg, width * 3)),\n"
"                    (60deg, width * 3),\n"
"                )\n"
"\n"
"                line(a, b, c, d, a)\n"
"\n"
"                let ang_eab = ang_deg\n"
"                let len_ae = width / calc.sin(60deg - ang_eab) * calc.sin(120deg)\n"
"                let e = (ang_eab, len_ae)\n"
"                let g = (a, 100%, 120deg, e)\n"
"                let f = (a, 100%, 60deg, e)\n"
"\n"
"                line(a, e, f, g, a)\n"
"                line(a, f)\n"
"\n"
"                for (pos, rel, lab) in (\n"
"                    (a, (-1, -1.2), $A$),\n"
"                    (b, (1, -1.5), $B$),\n"
"                    (c, (1, 1), $C$),\n"
"                    (d, (-1, 1), $D$),\n"
"                    (f, (-.5, 1.5), $F$),\n"
"                    (g, (-1, 1), $G$),\n"
"                    (e, (1, -.5), $E$),\n"
"                ) {\n"
"                    content((pos, 17%, (rel: rel)), lab)\n"
"                }\n"
"            })\n"
"            \"\"\",\n"
"            {\n"
"                'angle': 30,\n"
"            },\n"
"            post=lambda typ: typ.points.next_to(DR * 2, UL),\n"
"        ).show()\n"
"\n"
"        self.play(\n"
"            # 在使用 can_keep_structure 之前请先查看文档！\n"
"            dtyp.anim_update(angle=45, can_keep_structure=True),\n"
"            duration=2,\n"
"        )\n"
"\n"
"        self.play(\n"
"            dtyp.anim_update(angle=5, can_keep_structure=True),\n"
"            duration=2,\n"
"        )"
msgstr ""
"from janim.imports import *\n"
"\n"
"class DynamicTypstExample(Timeline):\n"
"    def construct(self) -> None:\n"
"        dtyp = DynamicTypst(\n"
"            \"\"\"\n"
"            #import \"@preview/cetz:0.4.2\"\n"
"            #import \"@preview/cetz-plot:0.1.3\": *\n"
"\n"
"            #let width = 1\n"
"            #let ang_deg = angle * 1deg\n"
"\n"
"            #cetz.canvas({\n"
"                import cetz.draw: *\n"
"\n"
"                stroke((thickness: 0.7pt, join: \"round\", paint: white))\n"
"\n"
"                let (a, b, c, d) = (\n"
"                    (0, 0),\n"
"                    (width, 0),\n"
"                    (rel: (width, 0), to: (60deg, width * 3)),\n"
"                    (60deg, width * 3),\n"
"                )\n"
"\n"
"                line(a, b, c, d, a)\n"
"\n"
"                let ang_eab = ang_deg\n"
"                let len_ae = width / calc.sin(60deg - ang_eab) * calc.sin(120deg)\n"
"                let e = (ang_eab, len_ae)\n"
"                let g = (a, 100%, 120deg, e)\n"
"                let f = (a, 100%, 60deg, e)\n"
"\n"
"                line(a, e, f, g, a)\n"
"                line(a, f)\n"
"\n"
"                for (pos, rel, lab) in (\n"
"                    (a, (-1, -1.2), $A$),\n"
"                    (b, (1, -1.5), $B$),\n"
"                    (c, (1, 1), $C$),\n"
"                    (d, (-1, 1), $D$),\n"
"                    (f, (-.5, 1.5), $F$),\n"
"                    (g, (-1, 1), $G$),\n"
"                    (e, (1, -.5), $E$),\n"
"                ) {\n"
"                    content((pos, 17%, (rel: rel)), lab)\n"
"                }\n"
"            })\n"
"            \"\"\",\n"
"            {\n"
"                'angle': 30,\n"
"            },\n"
"            post=lambda typ: typ.points.next_to(DR * 2, UL),\n"
"        ).show()\n"
"\n"
"        self.play(\n"
"            # Please read the documentation before using can_keep_structure!\n"
"            dtyp.anim_update(angle=45, can_keep_structure=True),\n"
"            duration=2,\n"
"        )\n"
"\n"
"        self.play(\n"
"            dtyp.anim_update(angle=5, can_keep_structure=True),\n"
"            duration=2,\n"
"        )"

#: janim.items.svg.typst_types.DynamicTypst.anim_update:1 of
msgid "创建参数改变的动态动画"
msgstr "Create a dynamic animation for parameter changes"

#: janim.items.svg.typst_types.DynamicTypst.anim_update:3 of
msgid ""
"如果能保证动态过程不会改变物件结构， 可以传入 ``can_keep_structure`` 使其基于 :class:`~.GroupUpdater` 动态变化，否则默认使"
"用 :class:`~.ItemUpdater`"
msgstr ""
"If the dynamic process is guaranteed not to change the item's structure, pass ``can_keep_structure`` to update "
"using :class:`~.GroupUpdater`; otherwise it defaults to :class:`~.ItemUpdater`."

#: janim.items.svg.typst_types.DynamicTypst.anim_update:6 of
msgid "设置这个参数的动机是， :class:`~.GroupUpdater` 的性质更好，但是它需要物件结构不会改变的前提"
msgstr ""
"The motivation for this parameter is that :class:`~.GroupUpdater` behaves better, but it requires that the item structure "
"does not change"
