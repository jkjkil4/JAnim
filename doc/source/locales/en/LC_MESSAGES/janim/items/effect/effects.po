#: ../../source/janim/items/effect/effects.rst:2
msgid "effects"
msgstr "effects"

#: janim.items.effect.effects.Shadertoy:1 of
msgid "一个用于创建类似 Shadertoy 着色器效果的类"
msgstr "A class for creating Shadertoy-like shader effects"

#: janim.items.effect.effects.Shadertoy:3 of
msgid "例:"
msgstr "Example:"

#: janim.items.effect.effects.Shadertoy:5 of
#, python-brace-format
msgid ""
"Shadertoy(\n"
"    '''\n"
"    void mainImage( out vec4 fragColor, in vec2 fragCoord ) {\n"
"        vec2 uv = fragCoord.xy / iResolution.xy;\n"
"        vec3 color = vec3(uv.x, uv.y, 0.5);\n"
"        fragColor = vec4(color, 1.0);\n"
"    }\n"
"    '''\n"
").show()"
msgstr ""
"Shadertoy(\n"
"    '''\n"
"    void mainImage( out vec4 fragColor, in vec2 fragCoord ) {\n"
"        vec2 uv = fragCoord.xy / iResolution.xy;\n"
"        vec3 color = vec3(uv.x, uv.y, 0.5);\n"
"        fragColor = vec4(color, 1.0);\n"
"    }\n"
"    '''\n"
").show()"

#: janim.items.effect.effects.Shadertoy:19 of
msgid "如果该着色器代码中出现报错，会显示为 ``JA_SHADERTOY`` 中出现的"
msgstr "If an error occurs in the shader code, it will be displayed as occurring in ``JA_SHADERTOY``."
