#: ../../source/janim/items/group.rst:2
msgid "group"
msgstr "group"

#: janim.items.group.Group:1 of
msgid "物件组"
msgstr "Item group"

#: janim.items.group.Group:3 of
msgid "将物件组成一组"
msgstr "Group items together"

#: janim.items.group.NamedGroupMixin:1 of
msgid "方便用于例如 :class:`~.Axes` 继承的基础类"
msgstr "A convenient base class for inheritance by, for example, :class:`~.Axes`"

#: janim.items.group.NamedGroupMixin:3 of
msgid "另见 :class:`NamedGroup`"
msgstr "See also: :class:`NamedGroup`"

#: janim.items.group.NamedGroupMixin.add:1 of
msgid "向该物件添加子物件，并且可以通过具名参数设定具名子物件"
msgstr "Add child items to this item, and set named child items via keyword arguments"

#: ../../source/janim/items/group.rst
msgid "参数"
msgstr "Parameters"

#: janim.items.group.NamedGroupMixin.add:3 of
msgid "要添加的子物件"
msgstr "Child items to add"

#: janim.items.group.NamedGroupMixin.add:4 of
msgid "要添加的具名子物件"
msgstr "Named child items to add"

#: janim.items.group.NamedGroupMixin.add:5 of
msgid "默认为 ``False``，如果为 ``True``，那么插入到子物件列表的开头"
msgstr "Default is ``False``; if ``True``, insert at the beginning of the child-item list"

#: janim.items.group.NamedGroupMixin.insert:1 of
msgid "在指定索引位置插入子物件，并且可以通过具名参数设定具名子物件"
msgstr "Insert child items at the specified index, and set named child items via keyword arguments"

#: janim.items.group.NamedGroupMixin.insert:3 of
msgid "插入位置的索引"
msgstr "Index at which to insert"

#: janim.items.group.NamedGroupMixin.insert:4 of
msgid "要插入的子物件"
msgstr "Child items to insert"

#: janim.items.group.NamedGroupMixin.insert:5 of
msgid "要插入的具名子物件"
msgstr "Named child items to insert"

#: janim.items.group.NamedGroupMixin.remove:1 of
msgid "从该物件移除子物件"
msgstr "Remove child items from this item"

#: janim.items.group.NamedGroupMixin.remove:3 of
msgid "要移除的子物件或具名子物件的名称"
msgstr "Child items or names of named child items to remove"

#: janim.items.group.NamedGroupMixin.shuffle:1 of
msgid "随机打乱子物件的顺序"
msgstr "Randomly shuffle the order of child items"

#: janim.items.group.NamedGroupMixin.shuffle:5 of
msgid "该方法使用 :func:`random.shuffle` 进行随机打乱"
msgstr "This method uses :func:`random.shuffle` to shuffle"

#: janim.items.group.NamedGroupMixin.shuffle:7 of
msgid "如果需要可重复的随机结果，请在调用此方法前使用 :func:`random.seed` 设置随机数种子"
msgstr "For reproducible randomness, set the seed with :func:`random.seed` before calling this method"

#: janim.items.group.NamedGroupMixin.set_name:1 of
msgid "设置一个已有的子物件的对应名称"
msgstr "Set the name for an existing child item"

#: janim.items.group.NamedGroupMixin.set_name:3 of
msgid "一个已有的子物件"
msgstr "An existing child item"

#: janim.items.group.NamedGroupMixin.set_name:4 of
msgid "要设置的名称"
msgstr "The name to set"

#: janim.items.group.NamedGroupMixin.by_name:1 of
msgid "根据名称获取子物件"
msgstr "Get a child item by name"

#: janim.items.group.NamedGroupMixin.resolve:1 of
msgid "将具名子物件的内部索引关系整体解析为到物件的映射"
msgstr "Resolve the internal index mapping of named child items into a name-to-item map"

#: ../../source/janim/items/group.rst
msgid "返回"
msgstr "Returns"

#: janim.items.group.NamedGroupMixin.resolve:3 of
msgid "名称到子物件的映射字典"
msgstr "A mapping dictionary from names to child items"

#: janim.items.group.NamedGroupMixin.children_with_name:1 of
msgid ""
"返回的列表中与子物件列表相似，但是每个元素是一个包含 ``(单个子物件, 其对应的名称)`` 的元组，如果不是具名子物件则名称为 "
"``None``"
msgstr ""
"Returns a list similar to the children list, but each element is a tuple of ``(child item, its name)``. If the child item "
"is not named, the name is ``None``"

#: janim.items.group.NamedGroupMixin.copy:1 of
msgid "复制物件"
msgstr "Copy the item"

#: janim.items.group.NamedGroup:1 of
msgid "具名物件组，可以使用类似 ``group['name']`` 的形式来获取其中的具名物件"
msgstr "Named item group; you can access named items with syntax like ``group['name']``"

#: janim.items.group.NamedGroup:3 of
msgid "初始物件"
msgstr "Initial items"

#: janim.items.group.NamedGroup:4 of
msgid "初始具名物件"
msgstr "Initial named items"

#: janim.items.group.NamedGroup:6 of
msgid "也可以使用 :meth:`~.NamedGroupMixin.add` 或 :meth:`~.NamedGroupMixin.insert` 方法，传入具名参数来新增具名子物件"
msgstr ""
"You can also use :meth:`~.NamedGroupMixin.add` or :meth:`~.NamedGroupMixin.insert` and pass keyword arguments to add "
"named child items"

#: janim.items.group.NamedGroup:8 of
msgid "示例："
msgstr "Example:"

#: janim.items.group.NamedGroup:10 of
msgid ""
"group = NamedGroup(\n"
"    text=Text('lorem'),\n"
"    shape=Circle()\n"
")\n"
"group.points.arrange(DOWN, aligned_edge=LEFT)\n"
"\n"
"self.play(\n"
"    group['text'].anim.color.set(GREEN),\n"
"    group['shape'].anim.color.set(YELLOW),\n"
"    lag_ratio=0.5\n"
")\n"
"\n"
"def updater(group: NamedGroup, p: UpdaterParams) -> None:\n"
"    group.points.rotate(TAU * p.alpha)\n"
"    group['text'].color.mix(BLUE, p.alpha)\n"
"\n"
"self.play(\n"
"    GroupUpdater(group, updater)\n"
")"
msgstr ""
"group = NamedGroup(\n"
"    text=Text('lorem'),\n"
"    shape=Circle()\n"
")\n"
"group.points.arrange(DOWN, aligned_edge=LEFT)\n"
"\n"
"self.play(\n"
"    group['text'].anim.color.set(GREEN),\n"
"    group['shape'].anim.color.set(YELLOW),\n"
"    lag_ratio=0.5\n"
")\n"
"\n"
"def updater(group: NamedGroup, p: UpdaterParams) -> None:\n"
"    group.points.rotate(TAU * p.alpha)\n"
"    group['text'].color.mix(BLUE, p.alpha)\n"
"\n"
"self.play(\n"
"    GroupUpdater(group, updater)\n"
")"

#: janim.items.group.NamedGroup:34 of
msgid "无法像 :class:`Group` 那样使用初始化参数"
msgstr "Cannot use initialization parameters like :class:`Group`"

#: janim.items.group.NamedGroup:36 of
msgid "group = Group(..., color=RED)"
msgstr "group = Group(..., color=RED)"

#: janim.items.group.NamedGroup:40 of
msgid "为了解决这一问题，你可以写为"
msgstr "To resolve this, you can write:"

#: janim.items.group.NamedGroup:42 of
msgid ""
"group = NamedGroup(...)\n"
"group.set(color=RED)"
msgstr ""
"group = NamedGroup(...)\n"
"group.set(color=RED)"

#: janim.items.group.NamedGroup:49 of
msgid "如果你想要将 :class:`NamedGroup` 作为父类并继承，使用 :class:`NamedGroupMixin` 会是更好的选择"
msgstr "If you want to subclass :class:`NamedGroup`, using :class:`NamedGroupMixin` is a better choice"

#: janim.items.group.NamedGroup:51 of
msgid "因为它不会将所有 ``**kwargs`` 都吃掉，而是使用显式的 ``named`` 参数来指定具名子物件字典"
msgstr ""
"Because it does not consume all ``**kwargs``; instead it uses an explicit ``named`` parameter to specify the named child-"
"item dictionary"
